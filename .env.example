AUTH_SECRET=change-me-to-long-random-string
SUPABASE_URL=https://your-project.supabase.co
# Klucz publiczny (RLS). Moze byc w backendzie do odczytow, jesli tak skonfigurujesz polityki.
SUPABASE_ANON_KEY=your-anon-key
# WYMAGANY do zapisow (lokalizacje, ruchy): Supabase → Settings → API → service_role (secret).
# Nie commituj tej wartosci. Nie uzywaj w przegladarce ani NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-backend-only
